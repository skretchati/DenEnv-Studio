<UserControl x:Class="DevEnvStudio.Views.UserControls.BackupTableRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <!--  FIX: No ColorAnimation. Use Style.Triggers on the Border for IsMouseOver.
          This avoids the frozen-brush crash entirely.  -->
<Border Padding="14,7,14,7"
             BorderBrush="{StaticResource Brush.Separator}"
             BorderThickness="0,0,0,1"
             MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Brush.Table.Row.Hover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="14"/>
            </Grid.ColumnDefinitions>

            <!-- Name + icon + subtitle (e.g. "143 files • 12.5 MB") -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="IconBorder"
                        Width="22" Height="22"
                        CornerRadius="5"
                        Background="{DynamicResource Brush.Icon.Bg.Base}"
                        VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="IconPath"
                                  Fill="{DynamicResource Brush.Text.Secondary}"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TbName"
                               Style="{StaticResource Text.TableCell}"
                               MaxWidth="140"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TbSubtitle"
                               FontFamily="{StaticResource Font.Primary}"
                               FontSize="9"
                               Foreground="{StaticResource Brush.Text.Muted}"
                               MaxWidth="140"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Environment -->
            <TextBlock x:Name="TbEnvironment"
                       Grid.Column="1"
                       Style="{StaticResource Text.TableCellMuted}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Date -->
            <TextBlock x:Name="TbDate"
                       Grid.Column="2"
                       Style="{StaticResource Text.TableCellMuted}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Size -->
            <TextBlock x:Name="TbSize"
                       Grid.Column="3"
                       Style="{StaticResource Text.TableCellMuted}"
                       VerticalAlignment="Center"/>

            <!-- Status -->
            <StackPanel Grid.Column="4"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot"
                         Width="6" Height="6"
                         Fill="{DynamicResource Brush.Status.Success}"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="TbStatus"
                           Margin="5,0,0,0"
                           FontFamily="{StaticResource Font.Primary}"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.Status.Success}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Kebab -->
            <StackPanel Grid.Column="5"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Ellipse Width="3" Height="3" Fill="{DynamicResource Brush.Icon.Stroke}" Margin="0,1"/>
                <Ellipse Width="3" Height="3" Fill="{DynamicResource Brush.Icon.Stroke}" Margin="0,1"/>
                <Ellipse Width="3" Height="3" Fill="{DynamicResource Brush.Icon.Stroke}" Margin="0,1"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
