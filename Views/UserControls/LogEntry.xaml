<UserControl x:Class="DevEnvStudio.Views.UserControls.LogEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Grid Margin="0,4,0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="46"/>
            <ColumnDefinition Width="34"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Timestamp -->
        <TextBlock x:Name="TbTime"
                   Grid.Column="0"
                   FontFamily="{StaticResource Font.Mono}"
                   FontSize="10"
                   Foreground="{StaticResource Brush.Text.Muted}"
                   VerticalAlignment="Center"/>

        <!-- Level badge -->
        <Border x:Name="LevelBadge"
                Grid.Column="1"
                CornerRadius="3"
                Padding="4,1"
                Margin="0,0,6,0"
                VerticalAlignment="Center">
            <TextBlock x:Name="TbLevel"
                       FontFamily="{StaticResource Font.Primary}"
                       FontSize="9"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Message -->
        <TextBlock x:Name="TbMessage"
                   Grid.Column="2"
                   FontFamily="{StaticResource Font.Primary}"
                   FontSize="11"
                   Foreground="{StaticResource Brush.Text.Secondary}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   ToolTipService.ShowDuration="8000">
            <TextBlock.ToolTip>
                <ToolTip>
                    <TextBlock x:Name="TbMessageTooltip"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="11"/>
                </ToolTip>
            </TextBlock.ToolTip>
        </TextBlock>
    </Grid>
</UserControl>
