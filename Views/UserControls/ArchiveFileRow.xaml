<UserControl x:Class="DevEnvStudio.Views.UserControls.ArchiveFileRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <!--  FIX: Style.Triggers for hover, no ColorAnimation on frozen Transparent  -->
    <Border Padding="14,5,14,5">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Brush.Table.Row.Hover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <!-- Name + icon -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="14" Height="14">
                    <Canvas Width="24" Height="24">
                        <Path x:Name="IconPath"
                              Fill="{DynamicResource Brush.Status.Warning}"
                              Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                    </Canvas>
                </Viewbox>
                <TextBlock x:Name="TbName"
                           Margin="7,0,0,0"
                           FontFamily="{StaticResource Font.Primary}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.Text.Primary}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <TextBlock x:Name="TbSize"
                       Grid.Column="1"
                       FontFamily="{StaticResource Font.Primary}"
                       FontSize="11"
                       Foreground="{StaticResource Brush.Text.Muted}"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="TbType"
                       Grid.Column="2"
                       FontFamily="{StaticResource Font.Primary}"
                       FontSize="11"
                       Foreground="{StaticResource Brush.Text.Muted}"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
