<UserControl x:Class="DevEnvStudio.Views.UserControls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:DevEnvStudio.Services"
             Background="{StaticResource Brush.Window.Bg}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30,40,30" MaxWidth="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ HEADER ══════════════════════════════════════════════ -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SettingsTitle}"
                           Style="{StaticResource Text.PageTitle}"/>
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavSettings}"
                           Style="{StaticResource Text.PageSubtitle}" Margin="0,3,0,0" Opacity="0"/>
            </StackPanel>

            <!-- ══ LANGUAGE ════════════════════════════════════════════ -->
            <Border Grid.Row="2" Style="{StaticResource Style.Card}" Padding="20,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=LangLabel}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </StackPanel>

                    <!-- English -->
                    <RadioButton Grid.Column="1" GroupName="LangGroup"
                                 IsChecked="{Binding IsEnglish, Mode=TwoWay}"
                                 Style="{StaticResource Style.Btn.SecondaryRadio}"
                                 Padding="14,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=LangEn}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </RadioButton>

                    <!-- Russian -->
                    <RadioButton Grid.Column="3" GroupName="LangGroup"
                                 IsChecked="{Binding IsRussian, Mode=TwoWay}"
                                 Style="{StaticResource Style.Btn.SecondaryRadio}"
                                 Padding="14,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=LangRu}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- ══ PASSWORD PROTECTION ════════════════════════════════ -->
            <Border Grid.Row="4" Style="{StaticResource Style.Card}" Padding="20,18">
                <StackPanel>
                    <!-- Header row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordLabel}"
                                       FontFamily="{StaticResource Font.Primary}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text.Primary}"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordDesc}"
                                       FontFamily="{StaticResource Font.Primary}"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Enable toggle -->
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding PasswordEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Top" Margin="0,4,0,0"
                                  Foreground="{StaticResource Brush.Text.Primary}">
<TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordEnable}"
                                        FontFamily="{StaticResource Font.Primary}"
                                        FontSize="12"
                                        Foreground="{StaticResource Brush.Text.Primary}"/>
                        </CheckBox>
                    </Grid>

                    <!-- Password input fields (visible when enabled) -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding PasswordEnabled, Converter={StaticResource BoolToVisConverter}}">

                        <!-- Password field label + input -->
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordPlaceholder}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   Margin="0,0,0,6"/>
                        <Border Background="{StaticResource Brush.Card.Bg.Alt}"
                                CornerRadius="6" Padding="12,10,12,10" Margin="0,0,0,10">
                            <Grid>
                                <TextBox x:Name="PwdBox1"
                                         Text="{Binding PasswordText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource Font.Mono}"
                                         FontSize="13"
                                         Foreground="{StaticResource Brush.Text.Primary}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="{StaticResource Brush.Blue}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordPlaceholder}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.Text.Muted}"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding Text.Length, ElementName=PwdBox1, Converter={StaticResource EmptyToVisConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Confirm password field label + input -->
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordConfirm}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   Margin="0,0,0,6"/>
                        <Border Background="{StaticResource Brush.Card.Bg.Alt}"
                                CornerRadius="6" Padding="12,10,12,10" Margin="0,0,0,10">
                            <Grid>
                                <TextBox x:Name="PwdBox2"
                                         Text="{Binding PasswordConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource Font.Mono}"
                                         FontSize="13"
                                         Foreground="{StaticResource Brush.Text.Primary}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="{StaticResource Brush.Blue}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordConfirm}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.Text.Muted}"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding Text.Length, ElementName=PwdBox2, Converter={StaticResource EmptyToVisConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Save button -->
                        <Button Style="{StaticResource Style.Btn.Primary}"
                                Height="34" Padding="24,0"
                                HorizontalAlignment="Left"
                                Command="{Binding SavePasswordCommand}">
<TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordSave}"
                                        FontFamily="{StaticResource Font.Primary}"
                                        FontSize="12" FontWeight="SemiBold"
                                        Foreground="White"/>
                        </Button>

                        <!-- Message -->
                        <Border Background="{StaticResource Brush.Blue.Bg}"
                                CornerRadius="4" Padding="10,6"
                                Margin="0,8,0,0"
                                Visibility="{Binding PasswordMessageVisible, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock Text="{Binding PasswordMessage}"
                                       FontFamily="{StaticResource Font.Primary}"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.Blue.Light}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Already configured indicator — removed per user request.
                         When password is saved, the blue message above shows "Password saved".
                    -->
                </StackPanel>
            </Border>



            <!-- ══ RESTORE MODE ════════════════════════════════════════ -->
            <Border Grid.Row="6" Style="{StaticResource Style.Card}" Padding="20,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RestoreModeLabel}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </StackPanel>

                    <!-- Ask every time -->
                    <RadioButton Grid.Column="1" GroupName="RestoreGroup"
                                 IsChecked="{Binding RestoreModeAsk, Mode=TwoWay}"
                                 Style="{StaticResource Style.Btn.SecondaryRadio}"
                                 Padding="14,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RestoreModeAsk}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </RadioButton>

                    <!-- Use latest -->
                    <RadioButton Grid.Column="3" GroupName="RestoreGroup"
                                 IsChecked="{Binding RestoreModeLast, Mode=TwoWay}"
                                 Style="{StaticResource Style.Btn.SecondaryRadio}"
                                 Padding="14,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RestoreModeLast}"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- ══ CRASH DIAGNOSTIC LOG ═══════════════════════════════ -->
            <Border Grid.Row="8" Style="{StaticResource Style.Card}" Padding="20,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Crash Diagnostic Log"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                        <TextBlock Text="Writes crash diagnostics to devenv_crash_diag.log on your Desktop. Always created on crash even if disabled."
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="11"
                                   Foreground="{StaticResource Brush.Text.Muted}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding EnableCrashLog, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource Brush.Text.Primary}">
                        <TextBlock Text="Enabled"
                                   FontFamily="{StaticResource Font.Primary}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                    </CheckBox>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>