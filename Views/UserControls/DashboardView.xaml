<UserControl x:Class="DevEnvStudio.Views.UserControls.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:DevEnvStudio.Views.UserControls"
             xmlns:vm="clr-namespace:DevEnvStudio.ViewModels"
             xmlns:svc="clr-namespace:DevEnvStudio.Services"
             Background="{StaticResource Brush.Window.Bg}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="22,18,22,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ ROW 0: Header ══════════════════════════════════════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PageTitle}" Style="{StaticResource Text.PageTitle}"/>
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PageSubtitle}"
                               Style="{StaticResource Text.PageSubtitle}" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
    <Button Style="{StaticResource Style.Btn.Primary}"
        Height="34"
        Padding="14,0"
        Click="CreateBackup_Click">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="+"
                       FontSize="16"
                       FontWeight="Light"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,-3,5,0"/>
            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=CreateBackup}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Button>

    <Button Style="{StaticResource Style.Btn.Secondary}"
            Height="34"
            Padding="14,0"
            Margin="8,0,0,0"
            Click="RestoreFromHeader_Click">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RestoreBackup}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text.Primary}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Button>
</StackPanel>
            </Grid>

            <!-- ══ ROW 2: Stat Cards ════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Backups -->
                <Border Grid.Column="0" Style="{StaticResource Style.Card}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource Brush.Icon.Blue.Bg}" VerticalAlignment="Center">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource Brush.Icon.Stroke.Active}"
                                          Data="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.53 15.48 1 13 1c-1.32 0-2.6.53-3.54 1.46L7 5H4c-1.11 0-2 .89-2 2v11c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtBackupCount"
                                       Text="{Binding BackupCount, Mode=OneWay}"
                                       Style="{StaticResource Text.StatNumber}"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=StatBackups}" Style="{StaticResource Text.StatLabel}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="TxtTotalSize"
                                       Text="{Binding TotalBackupSize, Mode=OneWay}"
                                       Style="{StaticResource Text.StatSub}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Last Backup -->
                <Border Grid.Column="2" Style="{StaticResource Style.Card}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource Brush.Icon.Green.Bg}" VerticalAlignment="Center">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource Brush.Status.Success}"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=StatLastBackup}" Style="{StaticResource Text.StatLabel}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="TxtLastBackup"
                                       Text="{Binding LastBackupDate, Mode=OneWay}"
                                       Style="{StaticResource Text.StatSub}" Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Storage -->
                <Border Grid.Column="4" Style="{StaticResource Style.Card}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource Brush.Icon.Orange.Bg}" VerticalAlignment="Center">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource Brush.Status.Warning}"
                                          Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStoragePct"
                                       Text="{Binding StoragePctDisplay, Mode=OneWay}"
                                       Style="{StaticResource Text.StatNumber}"
                                       Foreground="{StaticResource Brush.Orange}"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=StatStorageUsed}" Style="{StaticResource Text.StatLabel}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="TxtStorageSub"
                                       Text="{Binding StorageDisplay, Mode=OneWay}"
                                       Style="{StaticResource Text.StatSub}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Free Space -->
                <Border Grid.Column="6" Style="{StaticResource Style.Card}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource Brush.Icon.Purple.Bg}" VerticalAlignment="Center">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource Brush.Purple}"
                                          Data="M6 2v6l2 2-2 2v6l6-3 6 3v-6l-2-2 2-2V2l-6 3-6-3zm4 2.76L12 3.5l2 1.26v4.48L12 10.5l-2-1.26V4.76zm-2 7.04l2-1.3 2 1.3-.01 4.68L12 17.5l-1.99-1.02.01-4.68z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtFreeSpace"
                                       Text="{Binding StorageFree, Mode=OneWay}"
                                       Style="{StaticResource Text.StatNumber}"
                                       Foreground="{StaticResource Brush.Purple}"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=StatFreeSpace}" Style="{StaticResource Text.StatLabel}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="TxtDriveLetter"
                                       Text="{Binding DriveLetter, Mode=OneWay}"
                                       Style="{StaticResource Text.StatSub}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ ROW 4: Three-column body ══════════════════════════ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="210"/>
                </Grid.ColumnDefinitions>

                <!-- ╔══ LEFT COLUMN ══╗ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Recent Backups card -->
                    <Border Grid.Row="0" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RecentBackups}"
                                       Style="{StaticResource Text.SectionHeader}" Margin="14,12,14,10"/>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>

                            <!-- Scan status bar -->
                            <Border Grid.Row="2" Background="{DynamicResource Brush.Status.Bg}" Padding="14,6"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource Brush.Icon.Stroke.Active}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ScanStatus, Mode=OneWay}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="11" Foreground="{StaticResource Brush.Text.Muted}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                </StackPanel>
                            </Border>

                            <!-- Selected backup indicator (visible when a backup is picked for restore) -->
                            <Border Grid.Row="2" Background="{DynamicResource Brush.Status.Bg}" Padding="14,6"
                                    Visibility="{Binding SelectedBackupName, Converter={StaticResource EmptyToVisConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                          Fill="{DynamicResource Brush.Status.Success}" Width="11" Height="11"
                                          Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontFamily="{StaticResource Font.Primary}"
                                               FontSize="11" Foreground="{StaticResource Brush.Green}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="400"
                                               Text="{Binding SelectedBackupName, StringFormat='Restoring: {0}'}"/>
                                </StackPanel>
                            </Border>

                            <!-- Table header -->
                            <Grid Grid.Row="3" Margin="14,8,14,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="14"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColName}"   Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColSource}" Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColDate}"   Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="3" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColSize}"   Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="4" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColStatus}" Style="{StaticResource Text.TableHeader}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Backup rows ListBox (live binding) -->
                    <Border Grid.Row="0" Margin="0,70,0,0"
                            BorderBrush="{StaticResource Brush.Card.Border}" BorderThickness="1,0,1,1"
                            CornerRadius="0,0,8,8"
                            Background="{StaticResource Brush.Card.Bg}">
                        <ItemsControl x:Name="BackupList"
                                      ItemsSource="{Binding Backups}"
                                      MaxHeight="240"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type svc:BackupItem}">
                                    <uc:BackupTableRow
                                        BackupName="{Binding Name}"
                                        Subtitle="{Binding ContentSummary}"
                                        Environment="{Binding Subtitle}"
                                        Date="{Binding Date}"
                                        Size="{Binding SizeFmt}"
                                        Status="{Binding Status}"
                                        IconType="{Binding IconType}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Logs card -->
                    <Border Grid.Row="2" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Logs}"
                                       Style="{StaticResource Text.SectionHeader}" Margin="14,12,14,10"/>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding LogEntries}"
                                          MaxHeight="200"
                                          Margin="14,6,14,10">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type svc:LogEntry}">
                                        <uc:LogEntry Time="{Binding Time}"
                                                     Level="{Binding LevelText}"
                                                     Message="{Binding Message}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ╔══ CENTER COLUMN ══╗ -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scan Progress card -->
                    <Border Grid.Row="0" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,12,14,10">
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ScanStatus}" Style="{StaticResource Text.SectionHeader}"/>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                        CornerRadius="10" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"  Value="Collapsed"/>
                                            <Setter Property="Background"  Value="{StaticResource Brush.Icon.Blue.Bg}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Scanning}" FontFamily="{StaticResource Font.Primary}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Blue}"/>
                                </Border>
                            </Grid>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>

                            <Grid Grid.Row="2" Margin="14,14,14,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Phase + count -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="8"
                                            Background="{DynamicResource Brush.Badge.Bg}" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="{DynamicResource Brush.Text.Secondary}"
                                                      Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ScanPhase, Mode=OneWay}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                                        <TextBlock Text="{Binding ScanStatus, Mode=OneWay}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding BackupCount, Mode=OneWay}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Blue}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Progress bar -->
                                <Grid Grid.Row="2">
                                    <ProgressBar Style="{StaticResource Style.ProgressBar}"
                                                 Value="{Binding StoragePctNum}"
                                                 Height="7"/>
                                    <!-- Animated scanning pulse overlay -->
                                    <Border Height="7" CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="60">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Background" Value="{DynamicResource Brush.Accent}"/>
                                                <Setter Property="Opacity" Value="0.7"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="ScanPulse">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="Opacity"
                                                                        From="0.2" To="0.8"
                                                                        Duration="0:0:0.8"
                                                                        AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="ScanPulse"/>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>

                                <Rectangle Grid.Row="4" Style="{StaticResource Style.HSeparator}"/>

                                <!-- Current file being scanned -->
                                <StackPanel Grid.Row="6">
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysCurrentPath}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="10"
                                               Foreground="{StaticResource Brush.Text.Muted}"/>
                                    <TextBlock Text="{Binding ScanCurrentPath, Mode=OneWay}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="10"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"
                                               MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Storage bar -->
                                <Grid Grid.Row="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysPrimaryUsage}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Text.Primary}"/>
                                        <TextBlock Text="{Binding StoragePctDisplay}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Brush.Blue}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar Grid.Row="2"
                                                 Style="{StaticResource Style.ProgressBar}"
                                                 Value="{Binding StoragePctNum}" Height="6"/>
                                    <Grid Grid.Row="4">
                                        <TextBlock Text="{Binding StorageUsed}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource Brush.Text.Muted}"/>
                                        <TextBlock Text="{Binding StorageTotal}"
                                                   FontFamily="{StaticResource Font.Primary}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource Brush.Text.Muted}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Restore Preview card (static) -->
                    <Border Grid.Row="2" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,12,14,10">
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=RestorePreview}" Style="{StaticResource Text.SectionHeader}"/>
                                <Button Style="{StaticResource Style.Btn.Link}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Click="OpenPreviewArchive_Click">
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=OpenArchive}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.Text.Link}"/>
                                </Button>
                            </Grid>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="14,10,14,6">
                                <Border CornerRadius="4" Background="{DynamicResource Brush.Badge.Bg}" Padding="7,3">
                                    <TextBlock Text="{Binding SelectedBackup.Name, FallbackValue='No backups yet', TargetNullValue='No backups yet'}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="11"
                                               Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </Border>
                                <Border CornerRadius="4" Background="{DynamicResource Brush.Badge.Bg}" Padding="7,3" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding SelectedBackup.Date, FallbackValue='—', TargetNullValue='—'}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="11"
                                               Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </Border>
                                <Border CornerRadius="4" Background="{DynamicResource Brush.Badge.Bg}" Padding="7,3" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding SelectedBackup.SizeFmt, FallbackValue='—', TargetNullValue='—'}"
                                               FontFamily="{StaticResource Font.Primary}"
                                               FontSize="11"
                                               Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="3" Margin="14,4,14,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColRestorePath}"  Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColRestoreSize}"  Style="{StaticResource Text.TableHeader}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ColRestoreType}"  Style="{StaticResource Text.TableHeader}"/>
                            </Grid>

                            <ItemsControl Grid.Row="4"
                                          ItemsSource="{Binding SelectedBackup.PreviewEntries}"
                                          Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type svc:ArchivePreviewEntry}">
                                        <uc:ArchiveFileRow RestorePath="{Binding RestorePath}"
                                                           FileSize="{Binding FileSize}"
                                                           FileType="{Binding FileType}"
                                                           IsFolder="{Binding IsFolder}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ╔══ RIGHT COLUMN ══╗ -->
                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- System Information -->
                    <Border Grid.Row="0" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SystemInformation}"
                                       Style="{StaticResource Text.SectionHeader}" Margin="14,12,14,10"/>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>
                            <StackPanel Grid.Row="2" Margin="14,10,14,12">
                                <uc:SysInfoRow Icon="OS"  Label="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysOs}"      Value="{Binding OsVersion}"/>
                                <uc:SysInfoRow Icon="CPU" Label="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysCpu}"     Value="{Binding CpuName}"/>
                                <uc:SysInfoRow Icon="RAM" Label="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysRam}"     Value="{Binding RamTotal}"/>
                                <uc:SysInfoRow Icon="HDD" Label="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysStorage}" Value="{Binding StorageDisplay}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Backup Destination -->
                    <Border Grid.Row="2" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=BackupDestination}"
                                       Style="{StaticResource Text.SectionHeader}" Margin="14,12,14,10"/>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>
                            <Grid Grid.Row="2" Margin="14,10,14,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysLocation}" Style="{StaticResource Text.SysInfoLabel}"/>
                                    <TextBlock Text="{Binding DriveLetter}" Style="{StaticResource Text.SysInfoValue}"/>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysType}" Style="{StaticResource Text.SysInfoLabel}"/>
                                    <TextBlock Text="{Binding DriveType}" Style="{StaticResource Text.SysInfoValue}"/>
                                </Grid>
                                <Grid Grid.Row="4">
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SysFreeSpace}" Style="{StaticResource Text.SysInfoLabel}"/>
                                    <TextBlock Text="{Binding StorageFree}" Style="{StaticResource Text.SysInfoValue}"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <Border Grid.Row="4" Style="{StaticResource Style.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Actions}"
                                       Style="{StaticResource Text.SectionHeader}" Margin="14,12,14,10"/>
                            <Rectangle Grid.Row="1" Style="{StaticResource Style.HSeparator}"/>
                            <StackPanel Grid.Row="2" Margin="8,4,8,8">
    <uc:ActionItem Icon="Backup"
                   Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionCreate}"
                   Subtitle="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionCreateSub}"
                   ActionClick="CreateBackupAction_Click"/>

    <uc:ActionItem Icon="Restore"
                   Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionRestore}"
                   Subtitle="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionRestoreSub}"
                   ActionClick="RestoreAction_Click"/>

    <uc:ActionItem Icon="Archive"
                   Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionArchive}"
                   Subtitle="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionArchiveSub}"
                   ActionClick="OpenArchiveAction_Click"/>

    <uc:ActionItem Icon="Compare"
                   Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionCompare}"
                   Subtitle="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=ActionCompareSub}"
                   ActionClick="CompareBackupsAction_Click"/>

    <!--uc:ActionItem Icon="Schedule"
                   Title="Schedules"
                   Subtitle="Manage backup schedules"/-->
</StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ══ ROW 5: Scan current path footer ════════════════════ -->
            <Border Grid.Row="5" Margin="0,8,0,0" Padding="12,6"
                    Background="{DynamicResource Brush.Status.Bg}" CornerRadius="6"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="5" Height="5" Fill="{DynamicResource Brush.Icon.Stroke.Active}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ScanCurrentPath, Mode=OneWay}"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="10"
                               Foreground="{StaticResource Brush.Text.Muted}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
