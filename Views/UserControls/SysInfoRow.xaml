<UserControl x:Class="DevEnvStudio.Views.UserControls.SysInfoRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Grid Margin="0,4,0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Icon -->
        <Viewbox Grid.Column="0" Width="13" Height="13" VerticalAlignment="Center">
            <Canvas Width="24" Height="24">
                <Path x:Name="IconPath"
                      Fill="{DynamicResource Brush.Icon.Stroke}"
                      Data="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/>
            </Canvas>
        </Viewbox>

        <!-- Label -->
        <TextBlock x:Name="TbLabel"
                   Grid.Column="1"
                   Style="{StaticResource Text.SysInfoLabel}"
                   VerticalAlignment="Center"/>

        <!-- Value -->
        <TextBlock x:Name="TbValue"
                   Grid.Column="2"
                   Style="{StaticResource Text.SysInfoValue}"
                   VerticalAlignment="Center"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>
