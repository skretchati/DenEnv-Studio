<Window x:Class="DevEnvStudio.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:DevEnvStudio.Services"
        Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordPromptTitle}"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Window.Bg}"
        WindowStyle="SingleBorderWindow"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordLabel}"
                       FontFamily="{StaticResource Font.Primary}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text.Primary}"/>
            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordPromptDesc}"
                       FontFamily="{StaticResource Font.Primary}"
                       FontSize="11"
                       Foreground="{StaticResource Brush.Text.Muted}"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Brush.Card.Bg.Alt}"
                CornerRadius="6" Padding="12,10,12,10">
            <Grid>
                <PasswordBox x:Name="PwdBox"
                             FontFamily="{StaticResource Font.Mono}"
                             FontSize="13"
                             Foreground="{StaticResource Brush.Text.Primary}"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="{StaticResource Brush.Blue}"
                             KeyDown="PwdBox_KeyDown"
                             PasswordChanged="PwdBox_PasswordChanged"/>
                <TextBlock x:Name="PwdPlaceholder"
                           Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=PasswordPlaceholder}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="13"
                           Foreground="{StaticResource Brush.Text.Muted}"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource Style.Btn.Secondary}" Height="32" Padding="14,0"
                    Margin="0,0,8,0" Click="Cancel_Click"
                    IsCancel="True">
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Cancel}"
                           FontFamily="{StaticResource Font.Primary}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text.Primary}"/>
            </Button>
            <Button Style="{StaticResource Style.Btn.Primary}" Height="32" Padding="14,0"
                    Click="Ok_Click"
                    IsDefault="True">
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Ok}"
                           FontFamily="{StaticResource Font.Primary}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="White"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>