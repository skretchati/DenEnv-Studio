<Window x:Class="DevEnvStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:DevEnvStudio.Views.UserControls"
        xmlns:svc="clr-namespace:DevEnvStudio.Services"
        Title="DevEnv Studio"
        Width="1180"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Window.Bg}"
        ShowInTaskbar="True"
        Opacity="1"
        Visibility="Visible"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- WindowChrome: enables custom titlebar while keeping resize/move -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Background="{StaticResource Brush.Sidebar.Bg}"
              WindowChrome.IsHitTestVisibleInChrome="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0"
                        IsHitTestVisible="False">
                <Border Width="22" Height="22" CornerRadius="6" Background="{DynamicResource Brush.Logo.Bg}">
                    <Grid>
                        <Ellipse Width="10" Height="10"
                                 Fill="White" Opacity="0.15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                        <Path Data="M5,4 L5,10 L11,7 Z"
                              Fill="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Width="10" Height="10"
                              Stretch="Uniform"/>
                    </Grid>
                </Border>
                <TextBlock Text="DevEnv Studio"
                           Style="{StaticResource Text.Logo}"
                           Margin="7,0,0,0"/>
            </StackPanel>

            <!-- Drag region (transparent, captures drag via WindowChrome) -->
            <Border Grid.Column="1" Background="Transparent"/>

            <!-- Window controls -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <Button x:Name="BtnMinimize"
                        Style="{StaticResource Style.WinCtrl}"
                        Click="BtnMinimize_Click"
                        ToolTip="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Minimize}">
                    <!-- Minimize line: drawn with a Border, not a Path with Fill -->
                    <Border Width="12" Height="1.2"
                            Background="{StaticResource Brush.Text.Secondary}"
                            VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="BtnMaximize"
                        Style="{StaticResource Style.WinCtrl}"
                        Click="BtnMaximize_Click"
                        ToolTip="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Maximize}">
                    <Border Width="11" Height="11"
                            BorderBrush="{StaticResource Brush.Text.Secondary}"
                            BorderThickness="1.2"
                            CornerRadius="1"/>
                </Button>

                <Button x:Name="BtnClose"
                        Style="{StaticResource Style.WinCtrl.Close}"
                        Click="BtnClose_Click"
                        ToolTip="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=Close}">
                    <!-- X drawn with Rectangle rotations, not Path with Fill -->
                    <Grid Width="12" Height="12">
                        <Rectangle Width="14" Height="1.3"
                                   Fill="{StaticResource Brush.Text.Secondary}"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="45"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Width="14" Height="1.3"
                                   Fill="{StaticResource Brush.Text.Secondary}"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="-45"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Grid>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ══ BODY: SIDEBAR + CONTENT ════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─ SIDEBAR ──────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Brush.Sidebar.Gradient}"
                    BorderBrush="{StaticResource Brush.Separator}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="0" Margin="0,8,0,0">

                        <!-- Dashboard -->
                        <RadioButton Style="{StaticResource Style.NavItem}"
                                     IsChecked="True"
                                     x:Name="NavDashboard"
                                     Checked="NavDashboard_Checked">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="3" Canvas.Top="3"  Width="8" Height="8" Fill="{DynamicResource Brush.Icon.Stroke}"/>
                                        <Rectangle Canvas.Left="13" Canvas.Top="3" Width="8" Height="8" Fill="{DynamicResource Brush.Icon.Stroke}"/>
                                        <Rectangle Canvas.Left="3" Canvas.Top="13" Width="8" Height="8" Fill="{DynamicResource Brush.Icon.Stroke}"/>
                                        <Rectangle Canvas.Left="13" Canvas.Top="13" Width="8" Height="8" Fill="{DynamicResource Brush.Icon.Stroke}"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="TxtNavDashboard"
                                           Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavDashboard}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           VerticalAlignment="Center"
                                           Margin="9,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Backups -->
                        <RadioButton Style="{StaticResource Style.NavItem}"
                                     x:Name="NavBackups"
                                     Checked="NavBackups_Checked">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                              Data="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.53 15.48 1 13 1c-1.32 0-2.6.53-3.54 1.46L7 5H4c-1.11 0-2 .89-2 2v11c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavBackups}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           VerticalAlignment="Center"
                                           Margin="9,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Restore -->
                        <RadioButton Style="{StaticResource Style.NavItem}"
                                     x:Name="NavRestore"
                                     Checked="NavRestore_Checked">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                              Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavRestore}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           VerticalAlignment="Center"
                                           Margin="9,0,0,0"/>
                            </StackPanel>
                        </RadioButton>


                        <!-- Settings -->
                        <RadioButton Style="{StaticResource Style.NavItem}"
                                     x:Name="NavSettings"
                                     Checked="NavSettings_Checked">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                              Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.22-.07.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavSettings}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           VerticalAlignment="Center"
                                           Margin="9,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>

                    <!-- Bottom area -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">

                        <!-- Engine status -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="18,0,14,12"
                                    VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource Brush.Status.Success}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=EngineStatus}"
                                       FontFamily="{StaticResource Font.Primary}"
                                       FontSize="9"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=EngineIdle}"
                                       FontFamily="{StaticResource Font.Primary}"
                                       FontSize="9"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Help -->
                        <Button Style="{StaticResource Style.NavBottomBtn}" Height="38"
                                Click="HelpButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavHelp}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="9,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- About -->
                        <Button Style="{StaticResource Style.NavBottomBtn}" Height="38"
                                Click="AboutButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                              Data="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavAbout}"
                                           FontFamily="{StaticResource Font.Primary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Margin="9,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1" Fill="{StaticResource Brush.Separator}" Margin="14,6,14,6"/>

                        <!-- Settings gear -->
                        <Button Style="{StaticResource Style.NavBottomBtn}" Height="36"
                                Click="BtnSettings_Click">
                            <Viewbox Width="16" Height="16" Margin="1,0,0,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource Brush.Icon.Stroke}"
                                          Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.22-.07.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─ MAIN CONTENT ─────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{StaticResource Brush.Window.Bg}">
                <uc:DashboardView x:Name="DashboardPage" Visibility="Visible"/>
                <uc:BackupsView   x:Name="BackupsPage"   Visibility="Collapsed"/>
                <uc:RestoreView   x:Name="RestorePage"   Visibility="Collapsed"/>
                <uc:SettingsView  x:Name="SettingsPage"  Visibility="Collapsed"/>
            </Grid>

        </Grid>
    </Grid>
</Window>
