<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         PRIMITIVE COLORS
    ═══════════════════════════════════════════════════════ -->

    <Color x:Key="Col.Window.Bg">#0C0E17</Color>
    <Color x:Key="Col.Sidebar.Bg">#10121B</Color>
    <Color x:Key="Col.Sidebar.Bg.End">#0E1019</Color>
    <Color x:Key="Col.Card.Bg">#141620</Color>
    <Color x:Key="Col.Card.Bg.Alt">#12141D</Color>
    <Color x:Key="Col.Card.Header.Start">#171A28</Color>
    <Color x:Key="Col.Card.Border">#1B1E2E</Color>
    <Color x:Key="Col.Card.Border.Light">#252840</Color>
    <Color x:Key="Col.Hover.Bg">#181B2A</Color>
    <Color x:Key="Col.Row.Hover">#15182A</Color>
    <Color x:Key="Col.Separator">#1B1E2E</Color>

    <Color x:Key="Col.Icon.Bg.Base">#1A1D2E</Color>
    <Color x:Key="Col.Table.Row.Hover">#15182A</Color>
    <Color x:Key="Col.Status.Bg">#12141D</Color>
    <Color x:Key="Col.Badge.Bg">#1A1D2E</Color>

    <!-- Switchable accent for action / scan-pulse overlays -->
    <Color x:Key="Col.Accent">#4F88F5</Color>

    <!-- Icon strokes (sidebar nav icons) -->
    <Color x:Key="Col.Icon.Stroke">#4B5268</Color>
    <Color x:Key="Col.Icon.Stroke.Active">#4F88F5</Color>

    <!-- Progress bar gradient -->
    <Color x:Key="Col.Progress.Start">#3B74E8</Color>
    <Color x:Key="Col.Progress.End">#5B9BFF</Color>

    <!-- Scrollbar track / thumb / repeat buttons -->
    <Color x:Key="Col.ScrollBar.Thumb">#2E3250</Color>
    <Color x:Key="Col.ScrollBar.Thumb.Hover">#3E4470</Color>
    <Color x:Key="Col.ScrollBar.RepeatBtn">#2E3250</Color>

    <!-- Status dot palette (stat colors reused for dots/ellipses) -->
    <Color x:Key="Col.Status.Success">#22C55E</Color>
    <Color x:Key="Col.Status.Warning">#F59E0B</Color>

    <!-- Toggle button checked indicator (secondary radio buttons) -->
    <Color x:Key="Col.Radio.Checked.Bg">#2A2E45</Color>
    <Color x:Key="Col.Radio.Checked.Border">#3A3F5C</Color>

    <!-- Button Hover & Action Item Icon Bg -->
    <Color x:Key="Col.ActionItem.Icon.Bg">#1A1D2E</Color>
    <Color x:Key="Col.ActionItem.Hover">#181B2A</Color>

    <!-- Window control buttons -->
    <Color x:Key="Col.WinCtrl.Close.Hover.Text">White</Color>

    <!-- Password mode toggle visual placeholder -->
    <Color x:Key="Col.PasswordToggle.Bg">#1E2133</Color>

    <!-- Custom inline titlebar logo -->
    <Color x:Key="Col.Logo.Bg">#1E4FC2</Color>

    <Color x:Key="Col.Text.Primary">#E1E6F4</Color>
    <Color x:Key="Col.Text.Secondary">#8992AD</Color>
    <Color x:Key="Col.Text.Muted">#4B5268</Color>
    <Color x:Key="Col.Text.Link">#4F88F5</Color>
    <Color x:Key="Col.Text.Inverse">#0C0E17</Color>

    <Color x:Key="Col.Blue">#4F88F5</Color>
    <Color x:Key="Col.Blue.Light">#6B9CF8</Color>
    <Color x:Key="Col.Blue.Dark">#2E5ED0</Color>
    <Color x:Key="Col.Blue.Bg">#111E38</Color>
    <Color x:Key="Col.Blue.Bg.Subtle">#0E172E</Color>

    <Color x:Key="Col.Green">#22C55E</Color>
    <Color x:Key="Col.Green.Light">#4ADE80</Color>
    <Color x:Key="Col.Green.Bg">#0D3320</Color>

    <Color x:Key="Col.Orange">#F59E0B</Color>
    <Color x:Key="Col.Orange.Light">#FBB83E</Color>
    <Color x:Key="Col.Orange.Bg">#2A1D08</Color>

    <Color x:Key="Col.Purple">#A855F7</Color>
    <Color x:Key="Col.Purple.Light">#C084FC</Color>
    <Color x:Key="Col.Purple.Bg">#220E3A</Color>

    <Color x:Key="Col.Red">#EF4444</Color>
    <Color x:Key="Col.Red.Dark">#B91C1C</Color>
    <Color x:Key="Col.Red.Bg">#3C1010</Color>
    <Color x:Key="Col.Red.Bg.Hover">#501818</Color>

    <Color x:Key="Col.Nav.Active.Bg">#1A1D30</Color>
    <Color x:Key="Col.Nav.Hover.Bg">#17192A</Color>
    <Color x:Key="Col.Nav.Active.Indicator">#4F88F5</Color>

    <Color x:Key="Col.Btn.Primary">#2D62CC</Color>
    <Color x:Key="Col.Btn.Primary.Hover">#3972DC</Color>
    <Color x:Key="Col.Btn.Secondary">#1B1E2E</Color>
    <Color x:Key="Col.Btn.Secondary.Hover">#22263A</Color>
    <Color x:Key="Col.Btn.Secondary.Border">#252840</Color>

    <Color x:Key="Col.Progress.Track">#1B1E2E</Color>

    <Color x:Key="Col.Icon.Blue.Bg">#12244A</Color>
    <Color x:Key="Col.Icon.Green.Bg">#0B2E1C</Color>
    <Color x:Key="Col.Icon.Orange.Bg">#2C1E06</Color>
    <Color x:Key="Col.Icon.Purple.Bg">#1E0C38</Color>

    <Color x:Key="Col.WinCtrl.Hover">#252840</Color>
    <Color x:Key="Col.WinCtrl.Close.Hover">#C42B1C</Color>

    <!-- ═══════════════════════════════════════════════════════
         SOLID COLOR BRUSHES
    ═══════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="Brush.Window.Bg"        Color="{StaticResource Col.Window.Bg}"/>
    <SolidColorBrush x:Key="Brush.Sidebar.Bg"       Color="{StaticResource Col.Sidebar.Bg}"/>
    <SolidColorBrush x:Key="Brush.Card.Bg"          Color="{StaticResource Col.Card.Bg}"/>
    <SolidColorBrush x:Key="Brush.Card.Bg.Alt"      Color="{StaticResource Col.Card.Bg.Alt}"/>
    <SolidColorBrush x:Key="Brush.Card.Border"      Color="{StaticResource Col.Card.Border}"/>
    <SolidColorBrush x:Key="Brush.Card.Border.Light" Color="{StaticResource Col.Card.Border.Light}"/>
    <SolidColorBrush x:Key="Brush.Hover.Bg"         Color="{StaticResource Col.Hover.Bg}"/>
    <SolidColorBrush x:Key="Brush.Row.Hover"        Color="{StaticResource Col.Row.Hover}"/>
    <SolidColorBrush x:Key="Brush.Separator"        Color="{StaticResource Col.Separator}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary"     Color="{StaticResource Col.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary"   Color="{StaticResource Col.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted"       Color="{StaticResource Col.Text.Muted}"/>
    <SolidColorBrush x:Key="Brush.Text.Link"        Color="{StaticResource Col.Text.Link}"/>
    <SolidColorBrush x:Key="Brush.Text.Inverse"     Color="{StaticResource Col.Text.Inverse}"/>

    <SolidColorBrush x:Key="Brush.Blue"             Color="{StaticResource Col.Blue}"/>
    <SolidColorBrush x:Key="Brush.Blue.Light"       Color="{StaticResource Col.Blue.Light}"/>
    <SolidColorBrush x:Key="Brush.Blue.Dark"
                 Color="{StaticResource Col.Blue.Dark}"/>
    <SolidColorBrush x:Key="Brush.Blue.Bg"          Color="{StaticResource Col.Blue.Bg}"/>
    <SolidColorBrush x:Key="Brush.Green"            Color="{StaticResource Col.Green}"/>
    <SolidColorBrush x:Key="Brush.Green.Light"      Color="{StaticResource Col.Green.Light}"/>
    <SolidColorBrush x:Key="Brush.Green.Bg"         Color="{StaticResource Col.Green.Bg}"/>
    <SolidColorBrush x:Key="Brush.Orange"           Color="{StaticResource Col.Orange}"/>
    <SolidColorBrush x:Key="Brush.Orange.Bg"        Color="{StaticResource Col.Orange.Bg}"/>
    <SolidColorBrush x:Key="Brush.Purple"           Color="{StaticResource Col.Purple}"/>
    <SolidColorBrush x:Key="Brush.Purple.Bg"        Color="{StaticResource Col.Purple.Bg}"/>
<SolidColorBrush x:Key="Brush.Red"              Color="{StaticResource Col.Red}"/>
    <SolidColorBrush x:Key="Brush.Red.Dark"          Color="{StaticResource Col.Red.Dark}"/>
    <SolidColorBrush x:Key="Brush.Red.Bg"            Color="{StaticResource Col.Red.Bg}"/>
    <SolidColorBrush x:Key="Brush.Red.Bg.Hover"      Color="{StaticResource Col.Red.Bg.Hover}"/>

    <SolidColorBrush x:Key="Brush.Nav.Active.Bg"         Color="{StaticResource Col.Nav.Active.Bg}"/>
    <SolidColorBrush x:Key="Brush.Nav.Hover.Bg"          Color="{StaticResource Col.Nav.Hover.Bg}"/>
    <SolidColorBrush x:Key="Brush.Nav.Active.Indicator"  Color="{StaticResource Col.Nav.Active.Indicator}"/>

    <SolidColorBrush x:Key="Brush.Btn.Primary"           Color="{StaticResource Col.Btn.Primary}"/>
    <SolidColorBrush x:Key="Brush.Btn.Primary.Hover"     Color="{StaticResource Col.Btn.Primary.Hover}"/>
    <SolidColorBrush x:Key="Brush.Btn.Secondary"         Color="{StaticResource Col.Btn.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Btn.Secondary.Hover"   Color="{StaticResource Col.Btn.Secondary.Hover}"/>
    <SolidColorBrush x:Key="Brush.Btn.Secondary.Border"  Color="{StaticResource Col.Btn.Secondary.Border}"/>

    <SolidColorBrush x:Key="Brush.Progress.Track"        Color="{StaticResource Col.Progress.Track}"/>

    <SolidColorBrush x:Key="Brush.Icon.Blue.Bg"    Color="{StaticResource Col.Icon.Blue.Bg}"/>
    <SolidColorBrush x:Key="Brush.Icon.Green.Bg"   Color="{StaticResource Col.Icon.Green.Bg}"/>
    <SolidColorBrush x:Key="Brush.Icon.Orange.Bg"  Color="{StaticResource Col.Icon.Orange.Bg}"/>
    <SolidColorBrush x:Key="Brush.Icon.Purple.Bg"  Color="{StaticResource Col.Icon.Purple.Bg}"/>

    <SolidColorBrush x:Key="Brush.WinCtrl.Hover"       Color="{StaticResource Col.WinCtrl.Hover}"/>
    <SolidColorBrush x:Key="Brush.WinCtrl.Close.Hover" Color="{StaticResource Col.WinCtrl.Close.Hover}"/>

    <!-- Switchable brushes for theme-aware styles (added for light theme support) -->
    <SolidColorBrush x:Key="Brush.Icon.Bg.Base"          Color="{StaticResource Col.Icon.Bg.Base}"/>
    <SolidColorBrush x:Key="Brush.Table.Row.Hover"        Color="{StaticResource Col.Table.Row.Hover}"/>
    <SolidColorBrush x:Key="Brush.Status.Bg"              Color="{StaticResource Col.Status.Bg}"/>
    <SolidColorBrush x:Key="Brush.Badge.Bg"               Color="{StaticResource Col.Badge.Bg}"/>
    <SolidColorBrush x:Key="Brush.Accent"                 Color="{StaticResource Col.Accent}"/>
    <SolidColorBrush x:Key="Brush.Icon.Stroke"             Color="{StaticResource Col.Icon.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Icon.Stroke.Active"      Color="{StaticResource Col.Icon.Stroke.Active}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb"         Color="{StaticResource Col.ScrollBar.Thumb}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb.Hover"   Color="{StaticResource Col.ScrollBar.Thumb.Hover}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.RepeatBtn"      Color="{StaticResource Col.ScrollBar.RepeatBtn}"/>
    <SolidColorBrush x:Key="Brush.Status.Success"         Color="{StaticResource Col.Status.Success}"/>
    <SolidColorBrush x:Key="Brush.Status.Warning"         Color="{StaticResource Col.Status.Warning}"/>
    <SolidColorBrush x:Key="Brush.Radio.Checked.Bg"       Color="{StaticResource Col.Radio.Checked.Bg}"/>
    <SolidColorBrush x:Key="Brush.Radio.Checked.Border"   Color="{StaticResource Col.Radio.Checked.Border}"/>
    <SolidColorBrush x:Key="Brush.ActionItem.Icon.Bg"     Color="{StaticResource Col.ActionItem.Icon.Bg}"/>
    <SolidColorBrush x:Key="Brush.ActionItem.Hover"       Color="{StaticResource Col.ActionItem.Hover}"/>
    <SolidColorBrush x:Key="Brush.Logo.Bg"                Color="{StaticResource Col.Logo.Bg}"/>
    <SolidColorBrush x:Key="Brush.PasswordToggle.Bg"       Color="{StaticResource Col.PasswordToggle.Bg}"/>

    <SolidColorBrush x:Key="Brush.Transparent"     Color="Transparent"/>

    <!-- ═══════════════════════════════════════════════════════
         GRADIENT BRUSHES
    ═══════════════════════════════════════════════════════ -->

    <LinearGradientBrush x:Key="Brush.Progress.Fill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{DynamicResource Col.Progress.Start}" Offset="0"/>
        <GradientStop Color="{DynamicResource Col.Progress.End}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Sidebar.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Col.Sidebar.Bg}" Offset="0"/>
        <GradientStop Color="{StaticResource Col.Sidebar.Bg.End}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Card.Header.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Col.Card.Header.Start}" Offset="0"/>
        <GradientStop Color="{StaticResource Col.Card.Bg}" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
