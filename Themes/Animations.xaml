<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Corner Radii ════════════════════════════════════════════ -->
    <CornerRadius x:Key="Radius.Card">8</CornerRadius>
    <CornerRadius x:Key="Radius.Button">6</CornerRadius>
    <CornerRadius x:Key="Radius.Badge">4</CornerRadius>
    <CornerRadius x:Key="Radius.Icon">6</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">12</CornerRadius>
    <CornerRadius x:Key="Radius.Progress">4</CornerRadius>

    <!-- ══ Custom ScrollBar Thumb ══════════════════════════════════ -->
    <Style x:Key="Style.ScrollBar.Thumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="3" Background="{DynamicResource Brush.ScrollBar.Thumb}" Margin="2,0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Brush.ScrollBar.Thumb.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Vertical ScrollBar ══════════════════════════════════════ -->
    <Style x:Key="Style.ScrollBar.Vertical" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Style.ScrollBar.Thumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Horizontal ScrollBar ════════════════════════════════════ -->
    <Style x:Key="Style.ScrollBar.Horizontal" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="MinHeight" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Style.ScrollBar.Thumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ ScrollViewer ═════════════════════════════════════════════ -->
    <Style TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Orientation="Vertical"
                                   Minimum="0"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Style="{StaticResource Style.ScrollBar.Vertical}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Orientation="Horizontal"
                                   Minimum="0"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   Style="{StaticResource Style.ScrollBar.Horizontal}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ ProgressBar ══════════════════════════════════════════════ -->
    <Style x:Key="Style.ProgressBar" TargetType="ProgressBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="{StaticResource Brush.Progress.Track}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Progress.Fill}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="{StaticResource Radius.Progress}"
                            Background="{StaticResource Brush.Progress.Track}"
                            Height="{TemplateBinding Height}">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource Brush.Progress.Fill}"
                                    CornerRadius="{StaticResource Radius.Progress}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Sidebar Nav RadioButton ════════════════════════════════
         FIX: No ColorAnimation on frozen brushes.
              Use ControlTemplate Trigger property setters only.
              No Path.Fill bindings — hardcoded icon colors.
    ══════════════════════════════════════════════════════════════ -->
    <Style x:Key="Style.NavItem" TargetType="RadioButton">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="GroupName"                  Value="SidebarNavGroup"/>
        <Setter Property="Height"                     Value="44"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="BgBorder" Background="Transparent" CornerRadius="0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ActiveBar"
                                    Grid.Column="0"
                                    Background="Transparent"
                                    CornerRadius="0,2,2,0"/>
                            <ContentPresenter Grid.Column="1"
                                              Margin="14,0,12,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource Brush.Nav.Hover.Bg}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource Brush.Nav.Active.Bg}"/>
                            <Setter TargetName="ActiveBar" Property="Background" Value="{DynamicResource Brush.Nav.Active.Indicator}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Sidebar Bottom Button ════════════════════════════════════ -->
    <Style x:Key="Style.NavBottomBtn" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Height"                     Value="40"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter Margin="17,0,12,0" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.Nav.Hover.Bg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Primary Button ═══════════════════════════════════════════ -->
    <Style x:Key="Style.Btn.Primary" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Height"                     Value="34"/>
        <Setter Property="Padding"                    Value="16,0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Foreground"                 Value="White"/>
        <Setter Property="Background"                 Value="{StaticResource Brush.Btn.Primary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
        Background="{StaticResource Brush.Btn.Primary}"
                            CornerRadius="{StaticResource Radius.Button}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
<ControlTemplate.Triggers>
    <Trigger Property="IsMouseOver" Value="True">
    <Setter TargetName="Bg"
            Property="Background"
            Value="{StaticResource Brush.Btn.Secondary.Hover}"/>
</Trigger>

    <Trigger Property="IsPressed" Value="True">
    <Setter TargetName="Bg"
            Property="Background"
            Value="{StaticResource Brush.Blue.Dark}"/>
</Trigger>
</ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Secondary Button ══════════════════════════════════════════ -->
    <Style x:Key="Style.Btn.Secondary" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Height"                     Value="34"/>
        <Setter Property="Padding"                    Value="16,0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Foreground"                 Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Background"                 Value="{StaticResource Brush.Btn.Secondary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
        Background="{StaticResource Brush.Btn.Primary}"
                            BorderBrush="{StaticResource Brush.Btn.Secondary.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Button}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Btn.Secondary.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Secondary Radio Button (looks like a secondary button) ═══ -->
    <Style x:Key="Style.Btn.SecondaryRadio" TargetType="RadioButton">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Height"                     Value="34"/>
        <Setter Property="Padding"                    Value="16,0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Foreground"                 Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Background"                 Value="{StaticResource Brush.Btn.Secondary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bg"
                            Background="{StaticResource Brush.Btn.Secondary}"
                            BorderBrush="{StaticResource Brush.Btn.Secondary.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Button}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Btn.Secondary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.Radio.Checked.Bg}"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource Brush.Radio.Checked.Border}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Danger Button ═════════════════════════════════════════════ -->
    <Style x:Key="Style.Btn.Danger" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Height"                     Value="34"/>
        <Setter Property="Padding"                    Value="16,0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Foreground"                 Value="{StaticResource Brush.Red}"/>
        <Setter Property="Background"                 Value="{StaticResource Brush.Red.Bg}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
        Background="{StaticResource Brush.Btn.Primary}"
BorderBrush="{StaticResource Brush.Red.Dark}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Button}"
                                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Red.Bg.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Window Control Button ════════════════════════════════════ -->
    <Style x:Key="Style.WinCtrl" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="Width"                      Value="46"/>
        <Setter Property="Height"                     Value="32"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="Cursor"                     Value="Arrow"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.WinCtrl.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Style.WinCtrl.Close" TargetType="Button" BasedOn="{StaticResource Style.WinCtrl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.WinCtrl.Close.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Action Item Button ════════════════════════════════════════ -->
    <Style x:Key="Style.ActionItem" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"      Value="True"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Foreground"                 Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Padding"                    Value="0,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
        Background="{StaticResource Brush.Card.Bg}"
        BorderBrush="{StaticResource Brush.Card.Border}"
        BorderThickness="1"
        Padding="{TemplateBinding Padding}"
        CornerRadius="8">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
    <Setter TargetName="Bg"
            Property="Background"
            Value="{DynamicResource Brush.ActionItem.Hover}"/>

    <Setter TargetName="Bg"
            Property="BorderBrush"
            Value="{DynamicResource Brush.Card.Border.Light}"/>
</Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Link Button ═══════════════════════════════════════════════ -->
    <Style x:Key="Style.Btn.Link" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Cursor"    Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Link}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding"   Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Card Border ═══════════════════════════════════════════════ -->
    <Style x:Key="Style.Card" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Brush.Card.Bg}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Card.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource Radius.Card}"/>
    </Style>

    <!-- ══ Separator ══════════════════════════════════════════════════ -->
    <Style x:Key="Style.HSeparator" TargetType="Rectangle">
        <Setter Property="Height"  Value="1"/>
        <Setter Property="Fill"    Value="{StaticResource Brush.Separator}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- ══ ToolTip ════════════════════════════════════════════════════ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="{DynamicResource Brush.Card.Bg.Alt}"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Card.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Primary}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.XSmall}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="5">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
